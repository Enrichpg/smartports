# SmartPort Galicia Operations Center - Environment Variables
# Copy this file to .env and adjust values for your environment
# IMPORTANT: Do not commit .env to git; use .env.example as template

# ==================== ENVIRONMENT & LOGGING ====================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ==================== NGINX ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== BACKEND ====================
BACKEND_PORT=8000
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,nginx
API_V1_PREFIX=/api/v1

# ==================== DATABASE: PostgreSQL (Operational) ====================
POSTGRES_USER=smartports
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=smartports_db
POSTGRES_PORT=5432

# ==================== DATABASE: TimescaleDB (Time-Series) ====================
TIMESCALE_USER=quantumleap
TIMESCALE_PASSWORD=timescale123
TIMESCALE_DB=quantumleap
TIMESCALE_PORT=5433
POSTGRES_USE_SSL=False

# ==================== DATABASE: MongoDB ====================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_PORT=27017
MONGO_LD_DB=orion-ld
MONGO_IOT_DB=iot-agent

# ==================== CACHE & QUEUE: Redis ====================
REDIS_PASSWORD=redis123
REDIS_PORT=6379

# ==================== MESSAGE BROKER: MQTT ====================
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_WEBSOCKET_PORT=9001
MQTT_BROKER_URL=mqtt://mosquitto:1883

# ==================== FIWARE: Context Broker (Orion-LD) ====================
ORION_LD_PORT=1026
ORION_BASE_URL=http://orion-ld:1026
ORION_LOG_LEVEL=INFO

# ==================== FIWARE: IoT Agent JSON ====================
IOT_AGENT_API_PORT=4041
IOT_AGENT_HTTP_PORT=7896
IOT_AGENT_LOG_LEVEL=INFO

# ==================== FIWARE: QuantumLeap (Time-Series Manager) ====================
QUANTUMLEAP_PORT=8668
QUANTUMLEAP_BASE_URL=http://quantumleap:8668
QUANTUMLEAP_LOG_LEVEL=INFO

# ==================== BACKEND INTEGRATION ====================
DATABASE_URL=postgresql://smartports:postgres123@postgres:5432/smartports_db
REDIS_URL=redis://:redis123@redis:6379/0
CELERY_BROKER_URL=redis://:redis123@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis123@redis:6379/2

# ==================== GRAFANA ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_PORT=3000

# ==================== PROMETHEUS ====================
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_DAYS=15

# ==================== APPLICATION SETTINGS ====================
APP_NAME=SmartPort Galicia Operations Center
APP_VERSION=1.0.0
API_TITLE=SmartPort API
API_DESCRIPTION=Real-time multipurpose Galician port network operational platform
PUBLIC_BASE_URL=http://localhost

# ==================== MONITORING & ALERTS ====================
ENABLE_PROMETHEUS=true
ENABLE_GRAFANA=true
ENABLE_ALERTS=true
ALERT_THRESHOLD_OCCUPANCY=0.85
ALERT_THRESHOLD_DWELL_TIME=48

# ==================== FIWARE CONFIGURATION ====================
FIWARE_SERVICE=smartports
FIWARE_SERVICE_PATH=/Galicia
NGSI_LD_CONTEXT_URL=https://smartdatamodels.org/context.jsonld
NGSI_LD_VERSION=1.6

# ==================== ML & INTELLIGENCE (Optional) ====================
ENABLE_ML_FORECASTING=true
ENABLE_ML_RECOMMENDATIONS=true
FORECAST_HORIZON_DAYS=7
OLLAMA_BASE_URL=http://ollama:11434

# ==================== SECURITY (Production) ====================
# Use strong passwords and secrets in production
# Generate with: python -c "from secrets import token_urlsafe; print(token_urlsafe(32))"
SECURE_COOKIES=true
SECURE_CORS_ORIGINS=http://localhost,http://localhost:3000

# ==================== OPTIONAL: External Integrations ====================
# AIS Feed URL (vessel position data)
AIS_FEED_URL=https://example.com/ais
AIS_API_KEY=your-ais-api-key

# Weather API
WEATHER_API_URL=https://api.openweathermap.org/data/2.5
WEATHER_API_KEY=your-weather-api-key

# Air Quality API
AIR_QUALITY_API_URL=https://api.openweathermap.org/data/3.0
AIR_QUALITY_API_KEY=your-air-quality-api-key
