# SmartPort Galicia — Environment Configuration Template
# 
# Copy this file to .env and set production values
# IMPORTANT: Never commit .env to version control
#
# Last Updated: 2026-04-27

# ============================================================================
# FIWARE CORE SERVICES
# ============================================================================

# Orion-LD Context Broker
ORION_HOST=orion-ld
ORION_PORT=1026
ORION_VERSION=ld
ORION_SERVICE=smartport
ORION_SUBSERVICE=/galicia

# QuantumLeap Time-Series Manager
QUANTUMLEAP_HOST=quantumleap
QUANTUMLEAP_PORT=8668
QUANTUMLEAP_SERVICE=smartport
QUANTUMLEAP_SUBSERVICE=/galicia

# IoT Agent JSON
IOT_AGENT_HOST=iot-agent-json
IOT_AGENT_PORT=4041
IOT_AGENT_SERVICE=smartport
IOT_AGENT_SUBSERVICE=/galicia

# ============================================================================
# MESSAGE BROKER (MQTT)
# ============================================================================

MOSQUITTO_HOST=mosquitto
MOSQUITTO_PORT=1883
MOSQUITTO_USER=mqtt_user
MOSQUITTO_PASSWORD=mqtt_password_change_in_production
MOSQUITTO_TLS_ENABLED=false
MOSQUITTO_PROTOCOL_VERSION=mqtt311

# MQTT Topics Configuration
MQTT_TOPIC_SENSORS=devices/+/+
MQTT_TOPIC_PORTCALLS=portcalls/+/+
MQTT_TOPIC_OPERATIONS=operations/+/+
MQTT_TOPIC_VESSELS=vessels/+/+

# ============================================================================
# DATABASES - PostgreSQL (Operational)
# ============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=smartport_user
POSTGRES_PASSWORD=postgres_password_change_in_production
POSTGRES_DB=smartport
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres_admin_password_change_in_production

# Connection pooling
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_MIN_IDLE_CONNECTIONS=2
POSTGRES_CONNECTION_TIMEOUT_SECONDS=30

# Backup
POSTGRES_BACKUP_SCHEDULE="0 2 * * *"
POSTGRES_BACKUP_RETENTION_DAYS=30

# ============================================================================
# DATABASES - TimescaleDB (Time-Series)
# ============================================================================

TIMESCALEDB_HOST=timescaledb
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=quantumleap_user
TIMESCALEDB_PASSWORD=timescaledb_password_change_in_production
TIMESCALEDB_DB=quantumleap

# TimescaleDB specific settings
TIMESCALEDB_CHUNK_INTERVAL=1d
TIMESCALEDB_COMPRESSION_ENABLED=true
TIMESCALEDB_COMPRESSION_DELAY=7d
TIMESCALEDB_RETENTION_DAYS=1095

# ============================================================================
# DATABASES - MongoDB (Document Store)
# ============================================================================

MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=orion_user
MONGODB_PASSWORD=mongodb_password_change_in_production
MONGODB_DATABASE=oriondb
MONGODB_AUTHENTICATION_SOURCE=admin

# MongoDB replica set (if enabled)
MONGODB_REPLICA_SET=

# Backup
MONGODB_BACKUP_SCHEDULE="0 2 * * *"

# ============================================================================
# CACHE & MESSAGE QUEUE - Redis
# ============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production
REDIS_DB=0

# Main Redis URL (for caching and general use)
REDIS_URL=redis://:redis_password_change_in_production@redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://:redis_password_change_in_production@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password_change_in_production@redis:6379/2

# Cache settings
CACHE_TTL_PORT_SUMMARY=600
CACHE_TTL_PORT_ALERTS=300
CACHE_TTL_AVAILABILITY=600
CACHE_TTL_DEFAULT=300

# Celery Worker Configuration
CELERY_CONCURRENCY=4
CELERY_WORKER_LOG_LEVEL=info
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# ============================================================================
# REALTIME INFRASTRUCTURE - WebSocket, Audit, Events
# ============================================================================

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_HEARTBEAT_INTERVAL=30

# Audit Database Configuration (uses same PostgreSQL)
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=90
AUDIT_LOG_LEVEL=INFO

# Event Bus Configuration
EVENT_BUS_ENABLED=true
EVENT_BUS_MAX_EVENTS_IN_MEMORY=1000

# ============================================================================
# BACKEND - FastAPI
# ============================================================================

# Server configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WEBSOCKET_PORT=8001
BACKEND_WORKERS=4
BACKEND_TIMEOUT=30

# Application settings
BACKEND_DEBUG=false
BACKEND_RELOAD=false
BACKEND_LOG_LEVEL=INFO

# API Configuration
API_VERSION=1.0.0
API_TITLE=SmartPort Galicia API
API_DESCRIPTION=Intelligent operational management for Galician ports
API_CONTACT_NAME=SmartPort Team
API_CONTACT_EMAIL=support@smartport.local
API_CONTACT_URL=https://smartport.local

# CORS Configuration
CORS_ORIGINS=["http://localhost", "https://localhost", "http://localhost:3000", "https://smartport.local"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["Content-Type", "Authorization"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_min_128_chars_long_change_in_production_12345
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# OAuth2 (if enabled)
OAUTH2_ENABLED=false
OAUTH2_PROVIDER_URL=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# API Key (for external integrations)
API_KEY_ENABLED=false
API_KEY_HEADER=X-API-Key

# SSL/TLS Certificate Paths
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem
SSL_CA_BUNDLE_PATH=/etc/nginx/certs/ca-bundle.crt

# ============================================================================
# MACHINE LEARNING - FORECASTING
# ============================================================================

# Prophet Configuration
PROPHET_FORECAST_DAYS=7
PROPHET_FORECAST_INTERVAL_WIDTH=0.80
PROPHET_YEARLY_SEASONALITY=false
PROPHET_WEEKLY_SEASONALITY=true
PROPHET_DAILY_SEASONALITY=false

# Training Data
PROPHET_TRAINING_WINDOW_DAYS=90
PROPHET_HISTORICAL_LOOKBACK_DAYS=30

# Scheduling
PROPHET_RETRAIN_ENABLED=true
PROPHET_RETRAIN_SCHEDULE="0 6 * * *"
PROPHET_RETRAIN_TIMEOUT_MINUTES=30

# ============================================================================
# MACHINE LEARNING - RECOMMENDATIONS
# ============================================================================

# Random Forest Model Configuration
ML_RECOMMENDATION_MODEL_PATH=/app/models/berth_recommendation_rf.pkl
ML_RECOMMENDATION_MIN_FEATURES=5
ML_RECOMMENDATION_RETRAIN_SAMPLE_SIZE=1000

# Feature Importance Thresholds
ML_IMPORTANCE_AVAILABILITY=0.30
ML_IMPORTANCE_SERVICE_MATCH=0.25
ML_IMPORTANCE_EFFICIENCY=0.25
ML_IMPORTANCE_DISTANCE=0.20

# ============================================================================
# MACHINE LEARNING - LLM INTEGRATION
# ============================================================================

# Ollama Configuration
OLLAMA_ENABLED=true
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama2:13b
OLLAMA_TEMPERATURE=0.7
OLLAMA_CONTEXT_WINDOW=2048
OLLAMA_TIMEOUT_SECONDS=30

# LLM Tool Calling
LLM_TOOLS_ENABLED=true
LLM_TOOL_TIMEOUT_SECONDS=10

# System Prompt for SmartPort domain
LLM_SYSTEM_PROMPT="You are an intelligent assistant for SmartPort Galicia, a maritime port operations management system. You have access to real-time data about ports, berths, vessels, and environmental conditions in Galicia. Answer questions about port operations, occupancy, weather, and recommendations. Respond in the user's language (Galician, Spanish, or English). Use tool calls to retrieve data from the system."

# ============================================================================
# CELERY - ASYNC TASK QUEUE
# ============================================================================

# Celery Broker & Backend
CELERY_BROKER_URL=redis://:redis_password_change_in_production@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_password_change_in_production@redis:6379/1

# Celery Configuration
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC

# Task Routing
CELERY_TASK_ROUTING={
  "app.tasks.forecast_occupancy": {"queue": "forecast"},
  "app.tasks.recommend_berth": {"queue": "ml"},
  "app.tasks.send_alert_notification": {"queue": "alerts"}
}

# ============================================================================
# LOGGING
# ============================================================================

# Log Level
LOG_LEVEL=INFO
LOG_FORMAT=json

# Log Output
LOG_OUTPUT=stdout
LOG_FILE_PATH=/var/log/smartport/
LOG_FILE_ROTATION=daily
LOG_FILE_RETENTION_DAYS=30

# Structured Logging Fields
LOG_INCLUDE_CONTEXT=true
LOG_INCLUDE_TRACE_ID=true
LOG_INCLUDE_USER_ID=true

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_RETENTION_TIME=30d

# Application Metrics
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
METRICS_INCLUDE_REQUEST_TIME=true
METRICS_INCLUDE_DB_CONNECTIONS=true
METRICS_INCLUDE_CACHE_HITS=true

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INCLUDE_DB=true
HEALTH_CHECK_INCLUDE_ORION=true
HEALTH_CHECK_INCLUDE_QUANTUMLEAP=true

# ============================================================================
# NGINX - REVERSE PROXY & TLS
# ============================================================================

# Server Configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# SSL/TLS
NGINX_SSL_ENABLED=true
NGINX_SSL_CERT_PATH=/etc/nginx/certs/cert.pem
NGINX_SSL_KEY_PATH=/etc/nginx/certs/key.pem
NGINX_SSL_PROTOCOLS=TLSv1.2 TLSv1.3
NGINX_SSL_CIPHERS=HIGH:!aNULL:!MD5
NGINX_SSL_PREFER_SERVER_CIPHERS=on

# Rate Limiting
NGINX_RATE_LIMIT_ENABLED=true
NGINX_RATE_LIMIT_REQUESTS=100
NGINX_RATE_LIMIT_WINDOW=1m

# Compression
NGINX_GZIP_ENABLED=true
NGINX_GZIP_MIN_LENGTH=1000
NGINX_GZIP_TYPES=text/plain text/css application/json application/javascript

# Caching
NGINX_CACHE_ENABLED=true
NGINX_CACHE_STATIC_MAXAGE=86400
NGINX_CACHE_API_MAXAGE=0

# ============================================================================
# GRAFANA - DASHBOARDS & ANALYTICS
# ============================================================================

# Server Configuration
GRAFANA_HOST=0.0.0.0
GRAFANA_PORT=3000
GRAFANA_PROTOCOL=http
GRAFANA_DOMAIN=localhost

# Admin User
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_admin_password_change_in_production

# Data Source Configuration
GRAFANA_DATASOURCE_QUANTUMLEAP_URL=http://quantumleap:8668
GRAFANA_DATASOURCE_PROMETHEUS_URL=http://prometheus:9090

# ============================================================================
# APPLICATION SETTINGS - GALICIAN PORTS
# ============================================================================

# Pilot Ports Configuration (11 core ports)
PILOT_PORTS=CorA,Vigo,Ferrol,Marin,Vilagarcia,Ribeira,Burela,Celeiro,Cangas,Baiona,Viveiro

# Port Configuration
PORT_TIMEZONE=Europe/Madrid
PORT_CURRENCY=EUR
PORT_LANGUAGE=es

# Occupancy Thresholds
OCCUPANCY_ALERT_WARNING_THRESHOLD=75
OCCUPANCY_ALERT_CRITICAL_THRESHOLD=90

# Environmental Thresholds
AIR_QUALITY_PM25_ALERT_THRESHOLD=35
AIR_QUALITY_PM10_ALERT_THRESHOLD=50
WEATHER_WIND_ALERT_THRESHOLD=40

# Operational Rules
DWELL_TIME_WARNING_HOURS=48
DWELL_TIME_CRITICAL_HOURS=72
AUTHORIZATION_EXPIRY_WARNING_DAYS=30

# ============================================================================
# SITE / APPLICATION IDENTITY
# ============================================================================

SITE_NAME=SmartPort Galicia Operations Center
SITE_URL=https://smartport.local
SITE_LOGO_URL=https://smartport.local/static/logo.png
SITE_FAVICON_URL=https://smartport.local/static/favicon.ico

# Contact
SUPPORT_EMAIL=support@smartport.local
SUPPORT_PHONE=+34-1234-5678
SUPPORT_URL=https://smartport.local/support

# ============================================================================
# DEVELOPMENT / TESTING FLAGS
# ============================================================================

# Enable debug mode (only in development)
DEBUG_MODE=false

# Mock external services (for testing)
MOCK_MQTT_ENABLED=false
MOCK_AIS_ENABLED=false

# Test Data
GENERATE_SEED_DATA=false
SEED_DATA_PORTS=5
SEED_DATA_VESSELS=50
SEED_DATA_DAYS_HISTORY=90

# ============================================================================
# DOCKER COMPOSE SPECIFIC
# ============================================================================

# Docker Compose Network
COMPOSE_NETWORK=smartport_network

# Docker Compose Project Name
COMPOSE_PROJECT_NAME=smartport

# ============================================================================
# NOTES FOR PRODUCTION
# ============================================================================

# Security best practices:
# 1. Never commit .env to git
# 2. Change ALL passwords and secrets to strong values (min 16 chars)
# 3. Use environment variable encryption (HashiCorp Vault, AWS Secrets Manager)
# 4. Rotate JWT_SECRET_KEY periodically
# 5. Use SSL/TLS certificates from Let's Encrypt or trusted CA
# 6. Restrict network access (firewall rules)
# 7. Enable audit logging
# 8. Use separate .env files for dev, staging, production
# 9. Store sensitive values in secrets manager, not in .env
# 10. Regularly review and update dependencies

# Performance tuning:
# 1. Set BACKEND_WORKERS based on CPU cores (2-4x cores)
# 2. Tune database connection pool sizes
# 3. Configure Redis memory policies
# 4. Enable compression for HTTP responses
# 5. Set appropriate cache TTLs
# 6. Monitor and adjust CELERY worker counts

# Monitoring & alerting:
# 1. Enable Prometheus metrics
# 2. Set up AlertManager rules
# 3. Configure Grafana dashboards
# 4. Set up log aggregation (ELK, Datadog, etc.)
# 5. Monitor service health continuously
# 6. Alert on critical issues (>5% error rate, DB down, etc.)

# ============================================================================
